# Docker Compose Production Environment Variables
# Copy this file to .env and fill in the actual values
# NEVER commit real secrets!
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your actual values
#   docker compose -f docker-compose.prod.yml --env-file .env up -d

# ========== Database Configuration ==========
# PostgreSQL database credentials (choose secure passwords)
POSTGRES_USER=xgboost
POSTGRES_PASSWORD=changeme-to-secure-password
POSTGRES_DB=xgboost_vis

# Database connection URL (uses variables above)
# For Docker Compose, host is 'postgres' (service name)
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

# ========== Redis Configuration ==========
# Redis password (leave empty for no auth in development)
REDIS_PASSWORD=changeme-to-secure-password

# Redis connection URL (uses variable above)
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0

# ========== MinIO Object Storage Configuration ==========
# MinIO root credentials (choose secure passwords)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme-to-secure-password

# MinIO API credentials (for application access)
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=changeme-to-secure-key

# MinIO connection settings (internal Docker network)
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=xgboost-vis
MINIO_SECURE=false

# ========== Security Configuration ==========
# JWT secret key (at least 32 random characters)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=changeme-to-random-32-characters-at-least

# Default admin password for first login
ADMIN_DEFAULT_PASSWORD=admin123

# ========== Application Configuration ==========
# Workspace directory inside containers (mounted volume)
WORKSPACE_DIR=/app/workspace

# API URL for frontend (internal Docker network)
VITE_API_URL=http://api:8000

# CORS allowed origins (comma-separated, no spaces)
# Add your production domain(s) here
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ========== Optional Configuration ==========
# Storage type: local or minio
STORAGE_TYPE=minio

# Maximum concurrent training tasks
MAX_CONCURRENT_TRAININGS=3

# Training concurrency slots (Worker)
TRAINING_MAX_CONCURRENCY=2

# JWT token expiration in hours
JWT_EXPIRE_HOURS=24

# Training timeout in minutes
TRAINING_TIMEOUT_MINUTES=120

# Max upload file size in MB (0 = unlimited)
MAX_FILE_SIZE_MB=1024

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log format: text or json
LOG_FORMAT=text

# ========== Debug Mode ==========
DEBUG=false