{
  "name": "xgboost-training-visualizer",
  "version": "1.0.0-rc1",
  "private": true,
  "description": "XGBoost Training Visualizer - 面向建筑能耗时序建模的实验工作台",
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@xgboost-vis/web",
    "dev:api": "cd apps/api && uvicorn app.main:app --reload --port 8000",
    "dev:worker": "cd apps/worker && python -m app.main",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rimraf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "test": "turbo run test",
    "test:api": "cd apps/api && pytest",
    "test:worker": "cd apps/worker && pytest",
    "test:regression": "cd apps/api && python scripts/regression_check.py",
    "test:regression:path": "cd apps/api && python scripts/regression_check.py --path-only",
    "test:regression:smoke": "cd apps/api && python scripts/regression_check.py --smoke-only",
    "test:e2e:results": "cd apps/api && python scripts/e2e_validation.py --api-url http://localhost:8000",
    "test:e2e:results:json": "cd apps/api && python scripts/e2e_validation.py --output json --timeout 120",
    "docker:up": "docker-compose -f docker/docker-compose.yml up -d",
    "docker:down": "docker-compose -f docker/docker-compose.yml down",
    "docker:dev": "docker-compose -f docker/docker-compose.dev.yml up -d",
    "docker:logs": "docker-compose -f docker/docker-compose.yml logs -f",
    "db:migrate": "cd apps/api && alembic upgrade head",
    "db:revision": "cd apps/api && alembic revision --autogenerate -m",
    "install:py": "pip install -r apps/api/requirements.txt && pip install -r apps/worker/requirements.txt"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "eslint": "^8.57.0",
    "playwright": "^1.58.2",
    "prettier": "^3.2.0",
    "rimraf": "^5.0.0",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}