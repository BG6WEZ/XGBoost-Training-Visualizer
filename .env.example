# ===========================================
# XGBoost Training Visualizer 环境变量配置
# ===========================================
# 复制此文件为 .env 并根据实际环境修改各变量值
# cp .env.example .env
# ===========================================

# === 必须配置 ===

# 数据库连接 (PostgreSQL)
# 格式: postgresql://用户名:密码@主机:端口/数据库名
DATABASE_URL=postgresql://xgboost:xgboost123@localhost:5432/xgboost_vis

# JWT 密钥 (至少 32 字符的随机字符串，生产环境必须修改)
# 生成命令: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your-secret-key-here-replace-with-random-string

# Redis 连接
REDIS_URL=redis://localhost:6379/0

# 首次启动的默认管理员密码
ADMIN_DEFAULT_PASSWORD=admin123

# === 存储配置 ===

# 存储类型: local 或 minio
STORAGE_TYPE=local

# 工作目录 (训练输出、模型文件等，使用绝对路径)
WORKSPACE_DIR=/path/to/your/project/workspace

# 数据集目录 (使用绝对路径)
DATASET_DIR=/path/to/your/project/dataset

# === MinIO (当 STORAGE_TYPE=minio 时必须配置) ===
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=xgboost-vis
MINIO_SECURE=false

# === 可选配置 ===

# CORS 允许的源 (逗号分隔字符串)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# 最大并发训练任务数
MAX_CONCURRENT_TRAININGS=3

# 并发训练槽位数 (Worker 使用)
TRAINING_MAX_CONCURRENCY=2

# JWT Token 过期小时数
JWT_EXPIRE_HOURS=24

# 训练超时分钟数
TRAINING_TIMEOUT_MINUTES=120

# 最大上传文件大小 (MB，0 表示不限制)
MAX_FILE_SIZE_MB=1024

# 日志级别: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# 日志格式: text (人类可读) 或 json (结构化日志)
LOG_FORMAT=text

# 调试模式 (true/false)
DEBUG=false

# === 开发环境相关 ===
API_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000