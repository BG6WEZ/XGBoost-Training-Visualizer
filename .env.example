# ===========================================
# XGBoost Training Visualizer 环境变量配置
# ===========================================

# 数据库配置
DATABASE_URL=postgresql://xgboost:xgboost123@localhost:5432/xgboost_vis

# Redis 配置
REDIS_URL=redis://localhost:6379/0

# MinIO 对象存储配置
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=xgboost-vis
MINIO_SECURE=false

# 服务地址
API_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# JWT 配置
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRE_HOURS=24

# 训练配置
MAX_CONCURRENT_TRAININGS=3
TRAINING_TIMEOUT_MINUTES=120

# 存储配置（关键：API 和 Worker 必须使用相同的绝对路径）
# 默认值已基于项目根目录计算，通常无需手动设置
# 如需覆盖，请使用绝对路径，例如：
# WORKSPACE_DIR=C:/Users/wangd/project/XGBoost Training Visualizer/workspace
# DATASET_DIR=C:/Users/wangd/project/XGBoost Training Visualizer/dataset

# 文件上传配置
MAX_FILE_SIZE_MB=1024

# 日志级别
LOG_LEVEL=INFO